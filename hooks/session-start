#!/usr/bin/env bash
# Articulate — SessionStart hook
# 1. Streak reminder if at risk
# 2. Ambient coaching injection if enabled

set -euo pipefail

STATE_FILE="$HOME/.articulate/state.json"
USER_FILE="$HOME/.articulate/user.json"

# --- Detect platform ---
if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  PLATFORM="cursor"
else
  PLATFORM="claude"
fi

# --- JSON field reader (jq with grep/sed fallback) ---
read_json_field() {
  local file="$1" field="$2"
  if command -v jq >/dev/null 2>&1; then
    jq -r ".$field // empty" "$file" 2>/dev/null || echo ""
  else
    sed -n "s/.*\"$field\"[[:space:]]*:[[:space:]]*\"\{0,1\}\([^,\"}\r\n]*\)\"\{0,1\}.*/\1/p" "$file" 2>/dev/null | head -1
  fi
}

# --- 1. Streak reminder ---
STREAK_MSG=""

if [ -f "$STATE_FILE" ]; then
  STREAK=$(read_json_field "$STATE_FILE" "streak")
  LAST_PLAYED=$(read_json_field "$STATE_FILE" "lastPlayedDate")

  if [ -n "$STREAK" ] && [ "$STREAK" != "0" ] && [ "$STREAK" != "null" ] \
     && [ -n "$LAST_PLAYED" ] && [ "$LAST_PLAYED" != "null" ]; then

    # Cross-platform date math (BSD vs GNU)
    TODAY_EPOCH="" LAST_EPOCH=""
    if date -j -f "%Y-%m-%d" "2000-01-01" "+%s" >/dev/null 2>&1; then
      TODAY_EPOCH=$(date -j -f "%Y-%m-%d" "$(date +%Y-%m-%d)" "+%s")
      LAST_EPOCH=$(date -j -f "%Y-%m-%d" "$LAST_PLAYED" "+%s" 2>/dev/null || echo "")
    else
      TODAY_EPOCH=$(date -d "$(date +%Y-%m-%d)" "+%s")
      LAST_EPOCH=$(date -d "$LAST_PLAYED" "+%s" 2>/dev/null || echo "")
    fi

    if [ -n "$LAST_EPOCH" ]; then
      DAYS_SINCE=$(( (TODAY_EPOCH - LAST_EPOCH) / 86400 ))
      if [ "$DAYS_SINCE" -eq 1 ]; then
        STREAK_MSG="Your ${STREAK}-day streak is safe. Keep it going with /articulate"
      elif [ "$DAYS_SINCE" -ge 2 ]; then
        STREAK_MSG="🔥 Your **${STREAK}-day streak** is waiting. \`/articulate\` to keep it alive."
      fi
    fi
  fi
fi

# --- 2. Ambient coaching ---
COACHING_MSG=""

if [ -f "$USER_FILE" ]; then
  COACHING=$(read_json_field "$USER_FILE" "coachingEnabled")
  if [ "$COACHING" = "true" ]; then
    COACHING_MSG='You have Articulate ambient coaching enabled. When you notice the user writing with vague, hedging, or imprecise language in their messages to you, occasionally offer a brief inline vocabulary tip. Format: 💡 *You wrote "X" — try "Y" for [reason].* Rules: max once per 3-4 user messages, one line only, placed after your main response with a blank line separator, only target natural language (never code), skip if user is rushed/debugging/emotional, never suggest the same tip twice in a session. Focus on: vague nouns (thing/stuff), weak verbs (do/make/get), hedging (I think maybe), filler (basically/literally/just/really).'
  fi
fi

# --- Combine output ---
CONTEXT=""
if [ -n "$STREAK_MSG" ] && [ -n "$COACHING_MSG" ]; then
  CONTEXT="${STREAK_MSG}\\n\\n${COACHING_MSG}"
elif [ -n "$STREAK_MSG" ]; then
  CONTEXT="$STREAK_MSG"
elif [ -n "$COACHING_MSG" ]; then
  CONTEXT="$COACHING_MSG"
else
  exit 0
fi

# --- Output platform-specific JSON ---
if [ "$PLATFORM" = "cursor" ]; then
  printf '{"additional_context": "%s"}\n' "$CONTEXT"
else
  printf '{"hookSpecificOutput": {"hookEventName": "SessionStart", "additionalContext": "%s"}}\n' "$CONTEXT"
fi
